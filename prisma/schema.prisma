datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

// Table para sa mga Residente
model Resident {
  id          String   @id @default(uuid())
  name        String
  age         Int
  gender      String
  voterStatus String
  createdAt   DateTime @default(now())
}

// Table para sa mga Blotter Cases
model Blotter {
  id          String   @id @default(uuid())
  complainant String
  respondent  String
  incident    String
  status      String   @default("Active")
  date        String
  createdAt   DateTime @default(now())
}

// Table para sa Counters ng System (Clearance Document Tracker)
model SystemCounter {
  id    Int @id @default(1)
  count Int @default(0)
}
// Table para sa mga System Users (Admin, Secretary, atbp.)
model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String   // Dito ise-save ang password (in actual apps, dapat bcrypt ito)
  role      String   // "Admin" o "Secretary"
  name      String
  createdAt DateTime @default(now())
}